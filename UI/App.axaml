<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InstantCompress.App"
             RequestedThemeVariant="Default">
  <!-- RequestedThemeVariant="Default" follows the OS light/dark setting -->
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
</Application>
