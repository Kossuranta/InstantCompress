<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="InstantCompress.MainWindow"
        Icon="/Assets/icon.ico"
        Title="Instant Compress"
        Width="600" Height="540" CanResize="False"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <!-- theme-neutral grays/tints so light and dark both read fine without per-theme dictionaries -->
    <SolidColorBrush x:Key="Muted" Color="#8B939E" />
    <SolidColorBrush x:Key="Faint" Color="#55808080" />
    <SolidColorBrush x:Key="Accent" Color="#3B82F6" />
  </Window.Resources>

  <Window.Styles>
    <!-- Hand-rolled segmented control; Fluent has none -->
    <Style Selector="Border.seg">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{StaticResource Faint}" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="3" />
    </Style>
    <Style Selector="Border.seg ToggleButton">
      <Setter Property="Padding" Value="14,5" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <!-- Section box for the Custom settings page -->
    <Style Selector="Border.box">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{StaticResource Faint}" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="16,12" />
    </Style>
    <!-- Shared width for every Custom-settings numeric field, so they line up -->
    <Style Selector="NumericUpDown.field">
      <Setter Property="Width" Value="120" />
    </Style>
  </Window.Styles>

  <Panel>
  <StackPanel x:Name="MainPage" Margin="24,20" Spacing="12">
    <TextBlock Text="Instant Compress" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
      <StackPanel Spacing="4">
        <TextBlock Text="Compression amount" FontSize="12" Foreground="{StaticResource Muted}"
                   HorizontalAlignment="Center" />
        <Border Classes="seg">
          <StackPanel x:Name="PresetGroup" Orientation="Horizontal" Spacing="3">
            <ToggleButton Content="Low" Tag="low" Click="OnSegClick" />
            <ToggleButton Content="Medium" Tag="medium" IsChecked="True" Click="OnSegClick" />
            <ToggleButton Content="High" Tag="high" Click="OnSegClick" />
            <ToggleButton Content="Custom" Tag="custom" Click="OnSegClick" />
          </StackPanel>
        </Border>
        <TextBlock Text="Higher compression means lower image quality." FontSize="11"
                   Foreground="{StaticResource Muted}" HorizontalAlignment="Center"
                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="160" />
        <Panel Height="30">
          <Button x:Name="SettingsButton" Content="Settings" FontSize="11" Padding="10,4" IsVisible="False"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Click="OnSettingsClick" ToolTip.Tip="Custom quality &amp; resize" />
          <CheckBox x:Name="ResizeToggle" Content="Allow resizing images" FontSize="11"
                    HorizontalAlignment="Center" VerticalAlignment="Center" IsCheckedChanged="OnResizeToggled" />
        </Panel>
      </StackPanel>
      <StackPanel Spacing="4">
        <TextBlock Text="Result file type" FontSize="12" Foreground="{StaticResource Muted}"
                   HorizontalAlignment="Center" />
        <Border Classes="seg">
          <StackPanel x:Name="FormatGroup" Orientation="Horizontal" Spacing="3">
            <ToggleButton Content="JPG" Tag="jpg" IsChecked="True" Click="OnSegClick" />
            <ToggleButton Content="PNG" Tag="png" Click="OnSegClick" />
            <ToggleButton Content="WebP" Tag="webp" Click="OnSegClick" />
          </StackPanel>
        </Border>
      </StackPanel>
    </StackPanel>

    <!-- Solid border; Avalonia Border has no dash support -->
    <Border x:Name="DropZone" DragDrop.AllowDrop="True" MinHeight="220" CornerRadius="14"
            BorderThickness="2" BorderBrush="{StaticResource Faint}" Background="#10808080">
      <Panel>
        <StackPanel x:Name="IdlePanel" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
          <Path Data="M21,15 v4 a2,2 0 0 1 -2,2 H5 a2,2 0 0 1 -2,-2 v-4 M7,10 L12,15 L17,10 M12,15 L12,3"
                Stroke="{StaticResource Muted}" StrokeThickness="1.5"
                StrokeLineCap="Round" StrokeJoin="Round"
                Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center" />
          <TextBlock Text="Drag images or a folder here" Foreground="{StaticResource Muted}" HorizontalAlignment="Center" />
          <Button Content="Choose images…" HorizontalAlignment="Center" Click="OnChooseClick" />
        </StackPanel>

        <StackPanel x:Name="BusyPanel" IsVisible="False" VerticalAlignment="Center" Spacing="10" Margin="32,0">
          <TextBlock x:Name="CurrentFileText" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
          <ProgressBar x:Name="Bar" Minimum="0" Height="8" />
          <TextBlock x:Name="CounterText" FontSize="13" HorizontalAlignment="Center" />
          <Button Content="Cancel" HorizontalAlignment="Center" Click="OnCancelClick" />
        </StackPanel>
      </Panel>
    </Border>

    <Border x:Name="DonePanel" IsVisible="False" Background="#2216A34A" CornerRadius="10" Padding="12,10">
      <StackPanel Spacing="8">
        <SelectableTextBlock x:Name="DoneText" TextWrapping="Wrap" FontSize="13" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Open folder" Click="OnOpenFolderClick" />
          <Button Content="View results" Click="OnViewResultsClick" />
        </StackPanel>
      </StackPanel>
    </Border>

    <Border x:Name="ErrorPanel" IsVisible="False" Background="#22DC2626" CornerRadius="10"
            Padding="12,10" MaxHeight="110">
      <ScrollViewer>
        <TextBlock x:Name="ErrorsText" TextWrapping="Wrap" FontSize="13" />
      </ScrollViewer>
    </Border>
  </StackPanel>

  <StackPanel x:Name="SettingsPage" Margin="24,20" Spacing="16" IsVisible="False">
    <TextBlock Text="Custom settings" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />

    <Border Classes="box" HorizontalAlignment="Center">
      <StackPanel Spacing="10">
        <TextBlock Text="Quality" FontWeight="Bold" HorizontalAlignment="Center" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Slider x:Name="CustomSlider" Minimum="1" Maximum="100" Width="140" VerticalAlignment="Center"
                  ValueChanged="OnCustomSliderChanged" />
          <NumericUpDown x:Name="CustomValue" Classes="field" Minimum="1" Maximum="100" Increment="1"
                         ShowButtonSpinner="False" VerticalAlignment="Center"
                         FormatString="0" ValueChanged="OnCustomValueChanged" />
        </StackPanel>
      </StackPanel>
    </Border>

    <Border Classes="box" HorizontalAlignment="Center">
      <StackPanel Spacing="10">
        <TextBlock Text="Resize" FontWeight="Bold" HorizontalAlignment="Center" />

        <StackPanel Orientation="Horizontal" Spacing="8">
          <CheckBox x:Name="MaxWidthToggle" Content="Max width" Width="120" VerticalAlignment="Center"
                    IsCheckedChanged="OnMaxWidthToggled" />
          <NumericUpDown x:Name="MaxWidthValue" Classes="field" Minimum="16" Maximum="20000" Increment="64"
                         FormatString="0" ValueChanged="OnMaxWidthValueChanged" />
          <TextBlock Text="px" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <CheckBox x:Name="MaxHeightToggle" Content="Max height" Width="120" VerticalAlignment="Center"
                    IsCheckedChanged="OnMaxHeightToggled" />
          <NumericUpDown x:Name="MaxHeightValue" Classes="field" Minimum="16" Maximum="20000" Increment="64"
                         FormatString="0" ValueChanged="OnMaxHeightValueChanged" />
          <TextBlock Text="px" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <CheckBox x:Name="PercentageToggle" Content="Percentage" Width="120" VerticalAlignment="Center"
                    IsCheckedChanged="OnPercentageToggled" />
          <NumericUpDown x:Name="ScalePercentValue" Classes="field" Minimum="1" Maximum="100" Increment="5"
                         FormatString="0" ValueChanged="OnScalePercentValueChanged" />
          <TextBlock Text="%" VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>
    </Border>
  </StackPanel>

  <ToggleButton x:Name="ThemeToggle" Padding="12,5"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"
                Click="OnThemeToggleClick" ToolTip.Tip="Toggle dark/light theme" />
  <Button x:Name="BackButton" Content="Back" Padding="12,5" IsVisible="False"
          HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"
          Click="OnBackClick" ToolTip.Tip="Back to main page" />
  </Panel>
</Window>
